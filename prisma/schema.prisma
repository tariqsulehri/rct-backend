// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// REFERENCE DATA - Seeded once, rarely change
// ============================================================================

model Grade {
  id               Int     @id @default(autoincrement())
  department_id    Int
  code             String
  title            String
  level            Int
  experience_years Int
  performance_note String?

  department           Department                 @relation(fields: [department_id], references: [id], onDelete: Cascade)
  employees_current    Employee[]               @relation("CurrentGrade")
  employees_target     Employee[]               @relation("TargetGrade")
  grade_matrices       GradeMatrix[]
  domain_grade_weights SkillDomainGradeWeight[]

  @@unique([department_id, code])
  @@index([department_id])
  @@index([level])
  @@map("grades")
}

model SkillDomain {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  color       String? // Hex color for UI badges/visualization (e.g. '#3B82F6')

  domain_scores      DomainScore[]
  department_weights DepartmentDomainWeight[]
  competency_domains CompetencyDomainMap[]
  grade_weights      SkillDomainGradeWeight[]
  skill_assessments  SkillAssessment[]

  @@map("skill_domains")
}

model SkillDomainGradeWeight {
  id        Int   @id @default(autoincrement())
  domain_id Int
  grade_id  Int
  weight    Float // [0.0-1.0] domain contribution weight at this grade level

  domain SkillDomain @relation(fields: [domain_id], references: [id], onDelete: Cascade)
  grade  Grade       @relation(fields: [grade_id], references: [id], onDelete: Cascade)

  @@unique([domain_id, grade_id])
  @@index([domain_id])
  @@index([grade_id])
  @@map("skill_domain_grade_weights")
}

model CompetencyCategory {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  color       String? // Optional hex color for UI badges
  weight      Float   @default(1.0) // Future category/segment contribution weight
  sort_order  Int     @default(0)
  is_active   Boolean @default(true)

  competencies Competency[]

  @@index([is_active])
  @@index([sort_order])
  @@map("competency_categories")
}

model CompetencyDomainMap {
  id            Int @id @default(autoincrement())
  department_id Int
  competency_id Int
  domain_id     Int

  is_primary Boolean  @default(false) // Primary domain for this competency (for reporting)
  created_at DateTime @default(now())

  department Department  @relation(fields: [department_id], references: [id], onDelete: Cascade)
  competency Competency  @relation("CompetencyToDomains", fields: [competency_id], references: [id], onDelete: Cascade)
  domain     SkillDomain @relation(fields: [domain_id], references: [id], onDelete: Cascade)

  @@unique([department_id, competency_id, domain_id])
  @@index([department_id])
  @@index([competency_id])
  @@index([domain_id])
  @@map("competency_domain_maps")
}

model Competency {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String
  is_critical Boolean @default(false)

  // Categorization
  category_id         Int
  competency_category CompetencyCategory @relation(fields: [category_id], references: [id], onDelete: Restrict)

  // M-to-M relationship to domains (allows behavioral skills across multiple domains)
  competency_domains CompetencyDomainMap[] @relation("CompetencyToDomains")

  levels            CompetencyLevel[]
  technologies      Technology[]
  grade_matrices    GradeMatrix[]
  competency_scores CompetencyScore[]
  skill_assessments SkillAssessment[]

  @@index([category_id])
  @@map("competencies")
}

model CompetencyLevel {
  id            Int @id @default(autoincrement())
  competency_id Int
  level         Int // 1..5

  descriptor Json // Flexible descriptor with summary, kpis, behaviours, etc.

  competency Competency @relation(fields: [competency_id], references: [id], onDelete: Cascade)

  @@unique([competency_id, level])
  @@map("competency_levels")
}

model Technology {
  id            Int    @id @default(autoincrement())
  name          String
  competency_id Int

  competency        Competency        @relation(fields: [competency_id], references: [id], onDelete: Cascade)
  skill_assessments SkillAssessment[]

  @@unique([name, competency_id]) // duplicate guard: same name cannot appear twice under same competency
  @@index([competency_id])
  @@map("technologies")
}

model AssessmentTypeConfig {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  label       String
  weight      Float    @default(0)
  description String?
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  updated_at  DateTime @updatedAt

  @@map("assessment_type_configs")
}

model AssessmentLevelConfig {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  label       String
  weight      Float    @default(0)
  threshold   Float?
  description String?
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  updated_at  DateTime @updatedAt

  @@map("assessment_level_configs")
}

model AssessmentStatusConfig {
  id                  Int      @id @default(autoincrement())
  code                String   @unique
  label               String
  description         String?
  counts_toward_score Boolean  @default(false)
  is_terminal         Boolean  @default(false)
  sort_order          Int      @default(0)
  is_active           Boolean  @default(true)
  updated_at          DateTime @updatedAt

  @@map("assessment_status_configs")
}

model AssessmentProjectConfig {
  id                  Int      @id @default(autoincrement())
  project_count       Int      @unique
  label               String
  description         String?
  duration_months_min Int?
  duration_months_max Int?
  credit              Float
  threshold           Float?
  sort_order          Int      @default(0)
  is_active           Boolean  @default(true)
  updated_at          DateTime @updatedAt

  @@map("assessment_project_configs")
}

model Department {
  id              Int      @id @default(autoincrement())
  organization_id Int
  name            String
  description     String?
  created_at      DateTime @default(now())

  organization   Organization             @relation(fields: [organization_id], references: [id], onDelete: Restrict)
  employees      Employee[]
  config         DepartmentConfig?
  grades         Grade[]
  domain_weights DepartmentDomainWeight[]
  grade_matrices GradeMatrix[]
  competency_domain_maps CompetencyDomainMap[]
  skill_assessments SkillAssessment[]
  competency_scores CompetencyScore[]
  user_assignments UserDepartmentAssignment[]

  @@unique([organization_id, name])
  @@index([organization_id])
  @@map("departments")
}

model Organization {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  slug       String   @unique
  logo_url   String?
  base_url   String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  departments Department[]
  employees   Employee[]

  @@map("organizations")
}

model DepartmentConfig {
  id                      Int      @id @default(autoincrement())
  department_id           Int      @unique
  // Scoring formula weights — must sum to 1.0
  primary_weight          Float    @default(0.5)
  secondary_weight        Float    @default(0.3)
  tertiary_weight         Float    @default(0.2)
  // Grade matrix: use global by default, department override optional
  use_custom_grade_matrix Boolean  @default(false)
  notes                   String?
  updated_at              DateTime @updatedAt

  department Department @relation(fields: [department_id], references: [id], onDelete: Cascade)

  @@map("department_configs")
}

model DepartmentDomainWeight {
  id            Int     @id @default(autoincrement())
  department_id Int
  domain_id     Int
  weight        Float   @default(0.142857)
  is_active     Boolean @default(true)

  department Department  @relation(fields: [department_id], references: [id], onDelete: Cascade)
  domain     SkillDomain @relation(fields: [domain_id], references: [id], onDelete: Cascade)

  @@unique([department_id, domain_id])
  @@map("department_domain_weights")
}

// ============================================================================
// CONFIGURATION
// ============================================================================

model GradeMatrix {
  id            Int @id @default(autoincrement())
  department_id Int
  grade_id      Int
  competency_id Int

  threshold Float // Required score [0.0-1.0] for this grade

  department Department @relation(fields: [department_id], references: [id], onDelete: Cascade)
  grade      Grade      @relation(fields: [grade_id], references: [id], onDelete: Cascade)
  competency Competency @relation(fields: [competency_id], references: [id], onDelete: Cascade)

  @@unique([department_id, grade_id, competency_id])
  @@index([department_id])
  @@index([grade_id])
  @@index([competency_id])
  @@map("competency_grade_thresholds")
}

// ============================================================================
// AUTH & USERS
// ============================================================================

enum Role {
  ADMIN
  TOP_MANAGEMENT
  MANAGER
  LINE_MANAGER
  ENGINEER
}

model AccessRole {
  id          Int      @id @default(autoincrement())
  code        Role     @unique
  name        String
  description String?
  is_system   Boolean  @default(true)
  is_active   Boolean  @default(true)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  users User[]
  audit_logs AccessAuditLog[]
  role_permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  description String?
  category    String   @default("General")
  is_system   Boolean  @default(true)
  is_active   Boolean  @default(true)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  role_permissions RolePermission[]

  @@index([category])
  @@index([is_active])
  @@map("permissions")
}

model RolePermission {
  id            Int      @id @default(autoincrement())
  role_id       Int
  permission_id Int
  created_at    DateTime @default(now())

  role       AccessRole @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@unique([role_id, permission_id])
  @@index([role_id])
  @@index([permission_id])
  @@map("role_permissions")
}

model User {
  id            Int    @id @default(autoincrement())
  employee_id   Int    @unique
  role_id       Int?
  username      String @unique
  password_hash String // bcrypt cost 12
  role          Role

  is_active      Boolean   @default(true)
  login_attempts Int       @default(0)
  locked_until   DateTime? // Brute-force lockout
  last_login_at  DateTime?

  password_reset_token String?   @unique
  reset_token_expires  DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  employee       Employee       @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  role_ref       AccessRole?    @relation(fields: [role_id], references: [id], onDelete: SetNull)
  refresh_tokens RefreshToken[]
  department_assignments UserDepartmentAssignment[]
  line_manager_assignments EmployeeLineManagerAssignment[] @relation("LineManagerUser")
  created_department_assignments UserDepartmentAssignment[] @relation("CreatedDepartmentAssignments")
  created_line_manager_assignments EmployeeLineManagerAssignment[] @relation("CreatedLineManagerAssignments")
  access_audit_actions AccessAuditLog[] @relation("AccessAuditActor")
  access_audit_targets AccessAuditLog[] @relation("AccessAuditTarget")

  @@index([employee_id])
  @@index([role_id])
  @@index([username])
  @@map("users")
}

model UserDepartmentAssignment {
  id              Int      @id @default(autoincrement())
  user_id         Int
  department_id   Int
  assignment_type String   @default("MANAGER")
  can_view        Boolean  @default(true)
  can_manage      Boolean  @default(false)
  starts_at       DateTime @default(now())
  ends_at         DateTime?
  is_active       Boolean  @default(true)
  created_by      Int?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user       User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  department Department @relation(fields: [department_id], references: [id], onDelete: Cascade)
  creator    User?      @relation("CreatedDepartmentAssignments", fields: [created_by], references: [id], onDelete: SetNull)

  @@unique([user_id, department_id, assignment_type])
  @@index([user_id])
  @@index([department_id])
  @@index([is_active])
  @@map("user_department_assignments")
}

model EmployeeLineManagerAssignment {
  id                Int      @id @default(autoincrement())
  manager_user_id   Int
  employee_id       Int
  relationship_type String   @default("LINE_MANAGER")
  can_view          Boolean  @default(true)
  can_assess        Boolean  @default(true)
  starts_at         DateTime @default(now())
  ends_at           DateTime?
  is_primary        Boolean  @default(false)
  is_active         Boolean  @default(true)
  created_by        Int?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  manager_user User     @relation("LineManagerUser", fields: [manager_user_id], references: [id], onDelete: Cascade)
  employee     Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  creator      User?    @relation("CreatedLineManagerAssignments", fields: [created_by], references: [id], onDelete: SetNull)

  @@unique([manager_user_id, employee_id, relationship_type])
  @@index([manager_user_id])
  @@index([employee_id])
  @@index([is_active])
  @@map("employee_line_manager_assignments")
}

model AccessAuditLog {
  id             Int      @id @default(autoincrement())
  actor_user_id  Int?
  target_user_id Int?
  role_id        Int?
  action         String
  entity_type    String
  entity_id      Int?
  old_value      Json?
  new_value      Json?
  created_at     DateTime @default(now())

  actor_user  User?       @relation("AccessAuditActor", fields: [actor_user_id], references: [id], onDelete: SetNull)
  target_user User?       @relation("AccessAuditTarget", fields: [target_user_id], references: [id], onDelete: SetNull)
  role        AccessRole? @relation(fields: [role_id], references: [id], onDelete: SetNull)

  @@index([actor_user_id])
  @@index([target_user_id])
  @@index([role_id])
  @@index([entity_type, entity_id])
  @@index([created_at])
  @@map("access_audit_logs")
}

model RefreshToken {
  id      Int @id @default(autoincrement())
  user_id Int

  token_hash String @unique // SHA-256 hash of actual token

  expires_at DateTime
  revoked    Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("refresh_tokens")
}

// ============================================================================
// TRANSACTIONAL DATA
// ============================================================================

model Employee {
  id              Int     @id @default(autoincrement())
  organization_id Int
  emp_code        String  @unique
  full_name       String
  department      String
  email           String?

  current_grade_id Int
  target_grade_id  Int
  manager_id       Int?
  department_id    Int?

  deleted_at DateTime? // Soft delete
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  organization  Organization @relation(fields: [organization_id], references: [id], onDelete: Restrict)
  current_grade Grade        @relation("CurrentGrade", fields: [current_grade_id], references: [id])
  target_grade  Grade        @relation("TargetGrade", fields: [target_grade_id], references: [id])
  manager       Employee?    @relation("Reports", fields: [manager_id], references: [id])
  reports       Employee[]   @relation("Reports")
  dept          Department?  @relation(fields: [department_id], references: [id])

  user              User?
  line_manager_assignments EmployeeLineManagerAssignment[]
  skill_assessments SkillAssessment[]
  competency_scores CompetencyScore[]
  domain_scores     DomainScore[]

  @@index([manager_id])
  @@index([organization_id])
  @@index([current_grade_id])
  @@index([deleted_at])
  @@index([department_id])
  @@map("employees")
}

model SkillAssessment {
  id            Int @id @default(autoincrement())
  employee_id   Int
  department_id Int?
  domain_id     Int?
  competency_id Int?
  technology_id Int

  type     String // 'Primary' | 'Secondary' | 'Tertiary'
  projects Int // 0 | 1 | 2 | 3
  level    String  @default("Unset") // 'Expert' | 'Advanced' | 'Proficient' | 'Foundational' | 'Beginner' | 'Awareness' | 'Unset'
  score    Decimal @default(0) @db.Decimal(6, 2) // formula1(type,projects) × levelWeight — stored base score
  status   String  @default("approved") // 'approved' | 'pending'

  assessed_by Int
  assessed_at DateTime @default(now())
  updated_at  DateTime @updatedAt

  employee   Employee     @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  department Department?  @relation(fields: [department_id], references: [id], onDelete: SetNull)
  domain     SkillDomain? @relation(fields: [domain_id], references: [id], onDelete: SetNull)
  competency Competency?  @relation(fields: [competency_id], references: [id], onDelete: SetNull)
  technology Technology   @relation(fields: [technology_id], references: [id], onDelete: Cascade)

  @@unique([employee_id, technology_id]) // one assessment per employee per technology
  @@index([employee_id])
  @@index([department_id])
  @@index([domain_id])
  @@index([competency_id])
  @@index([technology_id])
  @@map("skill_assessments")
}

// ============================================================================
// COMPUTED DATA (populated synchronously after assessment changes)
// ============================================================================

model CompetencyScore {
  id            Int @id @default(autoincrement())
  employee_id   Int
  department_id Int?
  competency_id Int

  score       Float? // [0.0-1.0] or NULL
  level_label String? // 'L0 Developing' .. 'L4 Expert'
  star_rating Int? // 1..5

  updated_at DateTime @updatedAt

  employee   Employee    @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [department_id], references: [id], onDelete: SetNull)
  competency Competency  @relation(fields: [competency_id], references: [id], onDelete: Cascade)

  @@unique([employee_id, competency_id])
  @@index([employee_id])
  @@index([department_id])
  @@index([competency_id])
  @@map("competency_scores")
}

model DomainScore {
  id          Int @id @default(autoincrement())
  employee_id Int
  domain_id   Int

  score Float? // [0.0-1.0] or NULL

  updated_at DateTime @updatedAt

  employee Employee    @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  domain   SkillDomain @relation(fields: [domain_id], references: [id], onDelete: Cascade)

  @@unique([employee_id, domain_id])
  @@index([employee_id])
  @@map("domain_scores")
}
