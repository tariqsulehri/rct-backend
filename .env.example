# Database
DATABASE_URL=postgresql://postgres:@localhost:5432/devops_platform
DATABASE_READ_URL=postgresql://postgres:@localhost:5432/devops_platform
DB_USER=devops
DB_PASSWORD=devops_secure_pwd

# JWT secrets - change outside local development
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars-long
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-min-32-chars-long

# Application
NODE_ENV=development
API_PORT=4000
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=debug

# Cache
CACHE_TTL=300
